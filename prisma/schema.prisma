generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id            String   @id @default(uuid())
  name          String
  phoneNumberId String   @unique
  accessToken   String
  status        String   @default("active")
  createdAt     DateTime @default(now())
}